# BuenaPro local environment

# Database
DATABASE_URL=postgresql://buenapro:buenapro@localhost:5432/buenapro

# Auth.js / NextAuth
# Generate with: openssl rand -base64 32
AUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# Gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.1-flash-lite
GEMINI_ONBOARDING_MODEL=gemini-3.1-flash-lite
GEMINI_AGENT_MODEL=gemini-3.1-flash-lite
GEMINI_FALLBACK_MODEL=gemini-2.5-flash

# SEACE worker
SEACE_BASE_URL=https://prod6.seace.gob.pe/v1/s8uit-services
SEACE_USER_AGENT=BuenaPro/0.1 (+https://veyon-solutions.local)
SEACE_TIMEOUT_SECONDS=45
SEACE_POLL_INTERVAL_MINUTES=30
SEACE_LIFECYCLE_INTERVAL_HOURS=6
SEACE_CONTRACT_TEST_INTERVAL_MINUTES=60
SEACE_CONCURRENCY=3
# 32 bytes aleatorios codificados en base64. Nunca reutilizar AUTH_SECRET.
SEACE_CREDENTIALS_KEY_V1=
GEMINI_CONCURRENCY=1
WORKER_ID=local-worker

# MVP ingestion scope.
# 2 = Vigente
SEACE_ALLOWED_ESTADO_CONTRATO=2
# 2 = Servicio
SEACE_ALLOWED_CODIGO_OBJETO=2
# 43/81 = technology, 78 = transport, 80 = broad professional/legal bucket.
# Alcance actual del 24/7: solo tecnologia.
SEACE_ALLOWED_SEGMENTS=43,81

# Notifications MVP
EMAIL_FROM=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
TELEGRAM_BOT_TOKEN=

# Observability
SENTRY_DSN=
